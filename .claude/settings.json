{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "permissions": {
    "allow": ["Bash(git push origin main)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/humanize-check.mts",
            "timeout": 30,
            "statusMessage": "신규 포스트 윤문 여부 확인 중..."
          }
        ]
      }
    ]
  }
}
